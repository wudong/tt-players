data "aiven_service_component" "pg" {
  project      = var.aiven_project_name
  service_type = "pg"
  cloud_name   = var.region
}

output "available_plans" {
  value = distinct([for c in data.aiven_service_component.pg.components : c.service_type if c.service_type == "pg"])
  # This might not be right. Let me use aiven_service_plan_list if it exists.
}
