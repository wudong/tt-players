{
    "name": "@tt-players/worker",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "worker:start": "tsx src/worker.ts",
        "worker:scrape": "tsx src/scrape-once.ts",
        "worker:migrate": "tsx -e \"import { runMigrations } from 'graphile-worker'; runMigrations({ connectionString: process.env.DATABASE_URL }).then(() => console.log('Done'));\""
    },
    "dependencies": {
        "@tt-players/db": "workspace:*",
        "cheerio": "^1.2.0",
        "dotenv": "^16.4.7",
        "graphile-worker": "^0.16.6",
        "kysely": "^0.27.5",
        "pg": "^8.13.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/pg": "^8.11.11",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vitest": "^3.0.5"
    }
}